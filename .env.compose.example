# This file is the optional Compose override example. Use it only if you want
# to customize the packaged stack beyond the tracked defaults in
# `infra/compose/docker-compose.yml`.

PLATFORM_POSTGRES_PASSWORD=replace_me_in_local_env
PLATFORM_ADMIN_TOKEN=replace-with-local-admin-token
PLATFORM_ACCESS_TOKENS=replace-with-viewer-token:viewer:viewer-user,replace-with-editor-token:editor:editor-user
