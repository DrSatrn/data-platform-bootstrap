# This file documents the primary runtime configuration needed to launch the
# platform locally. The defaults assume Docker Compose and local ARM64 volumes.

PLATFORM_ENV=development
PLATFORM_HTTP_ADDR=:8080
PLATFORM_WEB_ADDR=:3000
PLATFORM_LOG_LEVEL=debug

PLATFORM_POSTGRES_DSN=postgres://platform:platform@postgres:5432/platform?sslmode=disable
PLATFORM_DUCKDB_PATH=/var/lib/platform/duckdb/platform.duckdb
PLATFORM_DATA_ROOT=/var/lib/platform/data
PLATFORM_ARTIFACT_ROOT=/var/lib/platform/artifacts
PLATFORM_MANIFEST_ROOT=/workspace/packages/manifests

PLATFORM_SCHEDULER_TICK=15s
PLATFORM_WORKER_POLL=5s
PLATFORM_MAX_CONCURRENT_JOBS=4
