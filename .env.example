# This file is the host-run example for local `go run` or built-binary
# workflows. The backend now auto-loads `.env` and `.env.local` from the repo
# root or the current working directory, so copying this file to `.env` is the
# intended local debugging path.

PLATFORM_ENV=development
PLATFORM_HTTP_ADDR=:8080
PLATFORM_WEB_ADDR=:3000
PLATFORM_API_BASE_URL=http://127.0.0.1:8080
PLATFORM_LOG_LEVEL=debug

PLATFORM_POSTGRES_DSN=postgres://platform_app:local_dev_password@localhost:5432/platform?sslmode=disable
PLATFORM_DUCKDB_PATH=../var/duckdb/platform.duckdb
PLATFORM_DATA_ROOT=../var/data
PLATFORM_ARTIFACT_ROOT=../var/artifacts
PLATFORM_MANIFEST_ROOT=../packages/manifests
PLATFORM_DASHBOARD_ROOT=../packages/dashboards
PLATFORM_SQL_ROOT=../packages/sql
PLATFORM_PYTHON_TASK_ROOT=../packages/python
PLATFORM_PYTHON_BINARY=python3
PLATFORM_SAMPLE_DATA_ROOT=../packages/sample_data
PLATFORM_MIGRATIONS_ROOT=../infra/migrations

PLATFORM_ADMIN_TOKEN=local-dev-admin-token
PLATFORM_ACCESS_TOKENS=viewer-token:viewer:viewer-user,editor-token:editor:editor-user

PLATFORM_SCHEDULER_TICK=15s
PLATFORM_WORKER_POLL=5s
PLATFORM_MAX_CONCURRENT_JOBS=4
